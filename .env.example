# Reference: all available environment variables for memoria-mcp.
# These are set in your Claude Desktop config (claude_desktop_config.json),
# NOT in this file. This file is for documentation only.
#
# Required: path to your memory data directory
MEMORIA_ROOT=/path/to/your/memoria

# Optional: customize file and directory names (defaults shown)
# MEMORIA_CONTEXT_FILE=context.md
# MEMORIA_STATE_FILE=_state.md
# MEMORIA_RETENTION_DAYS=14
# MEMORIA_DIR_SESSIONS=sessions
# MEMORIA_DIR_LOGS=logs
# MEMORIA_DIR_PROJECTS=projects
# MEMORIA_DIR_TOOLS=tools
# MEMORIA_DIR_CONTEXT=context
# MEMORIA_DIR_ARCHIVE=archive
